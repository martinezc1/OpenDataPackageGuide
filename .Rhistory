library(jsonlite)
library(tidyverse)
# Read the live metadata catalog
seattle_catalog <- fromJSON("https://data.seattle.gov/data.json")
# Extract the dataset array (conforming to the Project Open Data schema)
datasets_df <- seattle_catalog$dataset %>%
as_tibble() %>%
select(title, description, issued, modified, landingPage)
# View your new searchable index
glimpse(datasets_df)
View(datasets_df)
